# 数据库连接
DATABASE_URL=postgres://alethia:alethia@postgres:5432/alethia

# 后端服务端口
BRAIN_PORT=3000

# 登录 API 密钥（必须填写，前端登录时输入此值）
BRAIN_API_KEY=

# 全局语言（默认汉语）
LANGUAGE=zh-CN

# 日预算上限（美元）
DAILY_BUDGET=5
# 月预算上限（美元）
MONTHLY_BUDGET=50
# 单次问答预算上限（美元）
PER_QUERY_BUDGET=0.5

# 阿里云百炼（通义千问）
BAILIAN_API_KEY=
# 智谱 AI（ChatGLM）
ZHIPU_API_KEY=
# 月之暗面（Kimi / Moonshot）
MOONSHOT_API_KEY=
# 百度文心一言
ERNIE_API_KEY=
# 科大讯飞星火
SPARK_API_KEY=
# 腾讯混元
HUNYUAN_API_KEY=
# MiniMax
MINIMAX_API_KEY=
# DeepSeek
DEEPSEEK_API_KEY=
# 零一万物 Yi
YI_API_KEY=
# 百川智能
BAICHUAN_API_KEY=

# 嵌入模型（local=本地退化 all-MiniLM-L6-v2；或厂商适配器 ID）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# 重排序（默认关闭，开启需要 ZERANK_API_KEY）
RERANKER_ENABLED=false
ZERANK_API_KEY=

# NLI 预检服务（hf-inference 需要 HF_API_KEY；local=本地 transformers.js）
NLI_PROVIDER=local
HF_API_KEY=
