# PostgreSQL 配置（务必改为强密码；首次启动 docker compose 前需先创建 .env 并填入）
# DATABASE_URL 由 docker-compose.yml 自动从下方 POSTGRES_* 变量拼接，无需单独设置
# 如需自定义连接串，可在 docker-compose.yml 中覆盖 DATABASE_URL

POSTGRES_USER=alethia
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=alethia

# 后端服务端口
BRAIN_PORT=3000

# 登录 API 密钥（必须填写，前端登录时输入此值）
BRAIN_API_KEY=

# 全局语言（默认汉语）
LANGUAGE=zh-CN

# 日预算上限（美元）
DAILY_BUDGET=5
# 月预算上限（美元）
MONTHLY_BUDGET=50
# 单次问答预算上限（美元）
PER_QUERY_BUDGET=0.5

# 阿里云百炼（通义千问）
BAILIAN_API_KEY=
# 可覆盖 API 端点（用于代理、自部署模型等，留空使用默认端点）
# BAILIAN_BASE_URL=
# 智谱 AI（ChatGLM）
ZHIPU_API_KEY=
# ZHIPU_BASE_URL=
# 月之暗面（Kimi / Moonshot）
MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=
# 百度文心一言
ERNIE_API_KEY=
# ERNIE_BASE_URL=
# 科大讯飞星火
SPARK_API_KEY=
# SPARK_BASE_URL=
# 腾讯混元
HUNYUAN_API_KEY=
# HUNYUAN_BASE_URL=
# MiniMax
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=
# DeepSeek
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=
# 零一万物 Yi
YI_API_KEY=
# YI_BASE_URL=
# 百川智能
BAICHUAN_API_KEY=
# BAICHUAN_BASE_URL=

# 嵌入模型（local=本地退化 all-MiniLM-L6-v2；或厂商适配器 ID）
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# 重排序（默认关闭，开启需要 ZERANK_API_KEY）
RERANKER_ENABLED=false
ZERANK_API_KEY=

# NLI 预检服务（hf-inference 需要 HF_API_KEY；local=本地 transformers.js）
NLI_PROVIDER=local
HF_API_KEY=

# 数据存储路径（可自定义，留空使用默认 ./wiki ./raw 等）
# LIBRARY_PATH=/data/library
# WIKI_PATH=
# RAW_PATH=
# SUMMARIES_PATH=
# CHANGELOG_PATH=
