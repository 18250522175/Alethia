{
  "name": "@alethia/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts scripts/migrate.ts scripts/seed.ts --outdir dist --target bun",
    "db:migrate": "bun run scripts/migrate.ts",
    "seed": "bun run scripts/seed.ts",
    "brain": "bun run src/cli/brain.ts"
  },
  "dependencies": {
    "@extractus/article-extractor": "^8.0.0",
    "@hono/node-server": "^1.13.0",
    "@xenova/transformers": "^2.17.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.0",
    "kysely": "^0.27.0",
    "mammoth": "^1.8.0",
    "markdown-it": "^14.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "tesseract.js": "^5.1.0",
    "unified": "^11.0.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
